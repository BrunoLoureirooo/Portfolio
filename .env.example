# Build-time GitHub data (src/lib/github.ts). Copy this file to `.env` and fill
# in a token to make `pnpm build` fetch real data. Without it, the build uses
# deterministic mock data — nothing breaks. `.env` is git-ignored.

# GitHub personal access token (classic) with the `read:user` scope.
# github.com/settings/tokens → Generate new token (classic).
GITHUB_TOKEN=

# Optional — defaults to BrunoLoureirooo if unset.
GITHUB_USERNAME=BrunoLoureirooo

# Privacy-first analytics (Plausible). PUBLIC_ vars are exposed to the build.
# Leave unset → no analytics script ships (dev + unconfigured builds). Set to
# your Plausible site domain in production to enable cookieless tracking.
# PUBLIC_PLAUSIBLE_DOMAIN=brunoloureiro.dev
# Optional self-hosted Plausible script URL (defaults to plausible.io).
# PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- Call booking (docs/features/call-booking.md) ---
# These belong in `.dev.vars` locally (wrangler reads that, not .env) and in
# Cloudflare Pages secrets in prod. Mint the refresh token once with
# `node scripts/google-oauth.mjs`.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=
# Your real inbox (e.g. Proton) — added as attendee so every booking invite
# lands there, even though the calendar lives on the dedicated Google account.
# OWNER_NOTIFY_EMAIL=
# Local testing without Google creds: fake Meet link, no event created.
# BOOKING_DEV=1
