---
// GitHub — the activity section. Thin shell now: fetch the build-time data and
// mount the live island. All the mock/markup that used to live here moved into
// src/lib/github.ts (data) and Activity.tsx/.css (UI). See docs/features/github-data.md.
import Section from './Section.astro';
import Activity from './Activity';
import { getGitHubData } from '../lib/github';

// Runs at BUILD: real data if a token is set, otherwise deterministic mock.
// This object is the server-rendered first paint AND the island's initial props.
const data = await getGitHubData();
---

<Section id="github" title="GitHub activity" cmd="gh activity --live">
  {/*
    client:visible — Astro server-renders this island for first paint, then
    ships + hydrates its JS only once the section scrolls into view. After
    hydration it polls /api/activity every ~5 min. `data` is a superset of the
    island's ActivityData prop; langs is passed separately (static, build-time).
  */}
  <Activity client:visible initial={data} langs={data.langs} />
</Section>
