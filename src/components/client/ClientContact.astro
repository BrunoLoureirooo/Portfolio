---
// ClientContact (#contact · ./contact.sh) — the explicit close, in a green-wash
// panel. Two CTAs max: amber "book a call" (primary funnel) + green-hover email.
// Email comes from the CV contact block (one source, like Hero/Footer).
// PLACEHOLDER lead copy — finalized in step 4. Book-a-call URL is an open
// decision (Cal.com/Calendly vs mailto) — placeholder href for now.
import Section from '../Section.astro';
import BookingModal from './BookingModal';
import { getCvContent } from '../../lib/cvContent';
import { bookingUrl, bookingEnabled } from '../../config';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const { contact } = await getCvContent(Astro.currentLocale);

// Self-hosted booking modal (docs/features/call-booking.md) is built and
// tested but STUBBED OFF (bookingEnabled = false in config — see comment
// there) until the Google account behind it is finished. While off, the CTA
// is a plain mailto and a visible note says so — no modal is mounted, so
// there's no risk of a visitor hitting the unconfigured API. An external
// bookingUrl (if ever set) always bypasses the modal, enabled or not.
const showModal = bookingEnabled && !bookingUrl;
const bookHref =
  bookingUrl ??
  `mailto:${contact.email}?subject=${encodeURIComponent('20-min call')}`;

// Every string the island shows, translated here so it stays i18n-dumb.
const bookingLabels = {
  title: t('c.book.title'),
  loading: t('c.book.loading'),
  empty: t('c.book.empty'),
  tzNote: t('c.book.tz'),
  name: t('c.book.name'),
  email: t('c.book.email'),
  next: t('c.book.next'),
  submit: t('c.book.submit'),
  submitting: t('c.book.submitting'),
  confirmTitle: t('c.book.confirm.title'),
  confirmBody: t('c.book.confirm.body'),
  error: t('c.book.error'),
  back: t('c.book.back'),
  close: t('c.book.close'),
};
---

<Section
  id="contact"
  title={t('c.section.contact.title')}
  cmd={t('c.section.contact.cmd')}
>
  <div class="contact-panel">
    <p class="contact-panel__lead">{t('c.contact.lead')}</p>
    <div class="contact-panel__ctas">
      <a
        class="c-cta c-cta--primary"
        href={bookHref}
        data-cta="book"
        data-book={showModal ? true : undefined}
      >{t('c.cta.book')}</a>
      <a class="c-cta c-cta--ghost" href={`mailto:${contact.email}`}>{t('c.cta.email')}</a>
    </div>
    {!showModal && <p class="contact-panel__stub">{t('c.book.stub')}</p>}
  </div>
</Section>

{showModal && <BookingModal client:idle labels={bookingLabels} />}

<style>
  .contact-panel {
    padding: var(--space-8) var(--space-6);
    background-color: var(--panel);
    border: 1px solid var(--green-line);
    border-radius: var(--radius-md);
    box-shadow: var(--glow-window);
  }
  .contact-panel__lead {
    color: var(--green);
    font-size: var(--text-xl);
    text-shadow: var(--glow-green);
    margin-bottom: var(--space-6);
  }
  .contact-panel__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  /* Same treatment as the work-section "# concept demo" note — a terminal
     comment, not an apology. Only renders while bookingEnabled = false. */
  .contact-panel__stub {
    color: var(--dim);
    font-size: var(--text-sm);
    margin-top: var(--space-3);
  }
</style>
