---
// SampleCard — one repeatable case-study card, driven by the `samples`
// collection. Visual-first (media | details). Picks the current locale from
// each { en, pt } field. Honesty rule: badge is a concept-demo mark (amber
// "◆ …"), never a green "live"; facts are demo facts, not business results.
import { render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { useTranslations } from '../../i18n/utils';

interface Props {
  entry: CollectionEntry<'samples'>;
}

const { entry } = Astro.props;
const { data } = entry;
const t = useTranslations(Astro.currentLocale);
const locale = Astro.currentLocale === 'pt' ? 'pt' : 'en';
const hasMedia = data.media.length > 0;
// Markdown body → the closing founder-pricing / "studio work is new" note.
const { Content } = await render(entry);
---

<article class="sample">
  <div class="sample__media">
    {
      hasMedia ? (
        <img src={data.media[0]} alt={data.title[locale]} loading="lazy" />
      ) : data.demoUrl ? (
        <div
          class="sample__media-live"
          data-demo-url={data.demoUrl}
          data-demo-title={data.title[locale]}
          title={t('c.work.demo')}
        >
          <span class="sample__media-empty" aria-hidden="true">▮ preview</span>
          <iframe
            src={data.demoUrl}
            title={data.title[locale]}
            loading="lazy"
            tabindex="-1"
            aria-hidden="true"
          />
        </div>
      ) : (
        <span class="sample__media-empty" aria-hidden="true">▮ preview</span>
      )
    }
  </div>

  <div class="sample__body">
    <h3 class="sample__title">
      {data.title[locale]}
      <span class="sample__badge">◆ {data.badge[locale]}</span>
    </h3>

    {data.subtitle && <p class="sample__subtitle">{data.subtitle[locale]}</p>}
    <p class="sample__summary">{data.summary[locale]}</p>

    {
      data.facts.length > 0 && (
        <ul class="sample__facts">
          {data.facts.map((f) => (
            <li>
              <span class="sample__fact-value">{f.value}</span>
              <span class="sample__fact-label">{f.label[locale]}</span>
            </li>
          ))}
        </ul>
      )
    }

    {
      data.capabilities.length > 0 && (
        <ul class="sample__chips">
          {data.capabilities.map((c) => (
            <li>{c[locale]}</li>
          ))}
        </ul>
      )
    }

    {data.video && <a class="sample__video" href={data.video}>{t('c.work.video')}</a>}

    {
      (data.demoUrl || data.repo) && (
        <div class="sample__actions">
          {data.demoUrl && (
            <button
              class="sample__live"
              type="button"
              data-demo-url={data.demoUrl}
              data-demo-title={data.title[locale]}
            >
              {t('c.work.demo')}
            </button>
          )}
          {data.repo && (
            <a
              class="sample__repo"
              href={data.repo}
              target="_blank"
              rel="noopener noreferrer"
            >
              {t('c.work.repo')}
            </a>
          )}
        </div>
      )
    }

    <div class="sample__note"><Content /></div>
  </div>
</article>

<style>
  .sample {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: var(--space-6);
    padding: var(--space-5);
    background-color: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
  }

  .sample__media {
    display: grid;
    place-items: center;
    min-height: 200px;
    overflow: hidden;
    background-color: var(--bg);
    border: 1px dashed var(--border);
    border-radius: var(--radius-sm);
  }
  .sample__media:has(.sample__media-live) {
    border-style: solid;
    transition:
      box-shadow var(--duration-base) var(--ease-out-quart),
      border-color var(--duration-base) var(--ease-out-quart);
  }
  .sample__media:has(.sample__media-live:hover) {
    border-color: var(--green);
    box-shadow: var(--glow-green);
  }
  .sample__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .sample__media-empty {
    color: var(--muted);
  }

  /* Live preview — the demo site rendered at 4× the cell size, scaled to
     0.25 so it shows its desktop layout as a thumbnail. pointer-events off
     on the iframe → clicks land on the wrapper, which opens the DemoModal. */
  .sample__media-live {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 200px;
    display: grid;
    place-items: center;
    cursor: pointer;
    overflow: hidden;
  }
  .sample__media-live iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 400%;
    height: 400%;
    transform: scale(0.25);
    transform-origin: 0 0;
    border: 0;
    pointer-events: none;
  }

  .sample__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .sample__title {
    color: var(--green);
    font-size: var(--text-xl);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
  }
  .sample__badge {
    color: var(--accent);
    font-size: var(--text-xs);
    border: 1px solid var(--accent-ring);
    background-color: var(--accent-dim);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
  }
  .sample__subtitle {
    color: var(--muted);
    font-size: var(--text-sm);
  }
  .sample__summary {
    color: var(--fg);
    line-height: var(--leading-normal);
  }

  /* Demo facts — big glowing green numbers, dim label beneath. */
  .sample__facts {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-6);
    margin-block: var(--space-2);
  }
  .sample__facts li {
    display: flex;
    flex-direction: column;
  }
  .sample__fact-value {
    color: var(--green);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    text-shadow: var(--glow-green);
    font-variant-numeric: tabular-nums;
  }
  .sample__fact-label {
    color: var(--dim);
    font-size: var(--text-xs);
  }

  .sample__chips {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .sample__chips li {
    color: var(--green);
    font-size: var(--text-xs);
    border: 1px solid var(--green-line);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
  }

  .sample__video {
    align-self: flex-start;
    color: var(--accent);
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .sample__video:hover {
    text-decoration: underline;
  }

  /* Actions row — live demo is the star (green), source stays quiet. */
  .sample__actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  .sample__live {
    color: var(--green);
    background-color: var(--green-dim);
    border: 1px solid var(--green-line);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4);
    font: inherit;
    font-size: var(--text-sm);
    cursor: pointer;
    transition:
      box-shadow var(--duration-base) var(--ease-out-quart),
      border-color var(--duration-base) var(--ease-out-quart);
  }
  .sample__live:hover,
  .sample__live:focus-visible {
    border-color: var(--green);
    box-shadow: var(--glow-green);
  }
  .sample__repo {
    color: var(--muted);
    font-size: var(--text-sm);
    text-decoration: none;
  }
  .sample__repo:hover {
    color: var(--green);
  }

  .sample__note {
    color: var(--dim);
    font-size: var(--text-sm);
    margin-top: var(--space-2);
  }

  @media (max-width: 640px) {
    .sample {
      grid-template-columns: 1fr;
    }
  }
</style>
