---
// Projects — `ls -la ~/projects`. Thin shell: fetch build-time data for the
// server-rendered first paint, then mount the ProjectsCarousel island, which
// hydrates and refreshes live (same useGitHubData hook as Activity). The
// carousel + card styles live in ProjectsCarousel.css.
import Section from './Section.astro';
import ProjectsCarousel from './ProjectsCarousel';
import { getGitHubData } from '../lib/github';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);
const data = await getGitHubData();
---

<Section id="projects" title={t('section.projects.title')} cmd={t('section.projects.cmd')}>
  <ProjectsCarousel client:visible initial={data} locale={Astro.currentLocale} />
</Section>
