---
// Projects — `ls -la ~/projects` as a horizontal card carousel. Architecture-led
// framing: each card leads with what it is and the decisions behind it, not "a
// website I made" (see PRODUCT.md design principle 3).
//
// Data comes from the shared GitHub layer at build time (real repos when a token
// is set, deterministic mock otherwise). The carousel shows the strongest few on
// load — sorted by stars — and the rest are reachable by horizontal scroll.
import Section from './Section.astro';
import { getGitHubData } from '../lib/github';

const { projects } = await getGitHubData();
---

<Section id="projects" title="Projects" cmd="ls -la ~/projects">
  <ul
    class="projects"
    role="region"
    aria-label="Projects — scroll horizontally for more"
    tabindex="0"
  >
    {
      projects.map((p) => (
        <li class="card">
          <div class="card__head">
            <span class="card__name">▸ {p.name}</span>
            <span class={`card__status card__status--${p.status}`}>
              <span class="card__status-mark" aria-hidden="true">
                {p.status === 'active' ? '●' : '○'}
              </span>
              {p.status}
            </span>
          </div>

          <p class="card__desc">{p.description}</p>

          <ul class="card__tags">
            {p.tags.map((t) => (
              <li class="chip">{t}</li>
            ))}
          </ul>

          <div class="card__foot">
            <a class="card__link" href={p.repo}>
              git:repo →
            </a>
            {p.live && (
              <a class="card__link" href={p.live}>
                ↗ live
              </a>
            )}
            <span class="card__stars">★ {p.stars}</span>
          </div>
        </li>
      ))
    }
  </ul>
</Section>

<style>
  .projects {
    list-style: none;
    margin: 0;
    padding: 0;
    /* Carousel: one horizontal row that scrolls instead of wrapping. */
    display: flex;
    gap: var(--space-4);
    overflow-x: auto;
    /* Snap each card to the start edge as you scroll, so it never stops mid-card. */
    scroll-snap-type: x mandatory;
    /* A snapped card aligns flush with the row's left padding, not under it. */
    scroll-padding-inline: var(--space-1);
    padding-block: var(--space-2); /* room for the hover lift + focus ring */
  }
  /* Keyboard focus on the scroll region itself (it's tabindex=0). */
  .projects:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* Thin, themed scrollbar — keeps the "more to scroll" affordance without the
     chunky default bar. scrollbar-* is Firefox; ::-webkit-scrollbar is Chrome/Safari. */
  .projects {
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .projects::-webkit-scrollbar {
    height: 6px;
  }
  .projects::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: var(--radius-full);
  }

  .card {
    display: flex;
    flex-direction: column;
    /* Carousel item sizing: divide the row by ~3.2 so three cards show on load
       plus a sliver of the fourth — the visual cue that more exist. max() keeps
       cards readable (≥260px) on narrow screens, where fewer show + you scroll.
       flex-shrink 0 stops them squeezing instead of scrolling. */
    flex: 0 0 max(260px, calc((100% - 2 * var(--space-4)) / 3.2));
    scroll-snap-align: start;
    gap: var(--space-3);
    padding: var(--space-5);
    background-color: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    /* Lift + glow on hover. transform/box-shadow only — no layout reflow. */
    transition:
      transform var(--duration-base) var(--ease-out-quart),
      border-color var(--duration-base) var(--ease-out-quart),
      box-shadow var(--duration-base) var(--ease-out-quart);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--green);
    box-shadow: var(--glow-green);
  }

  .card__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .card__name {
    color: var(--green);
    font-weight: var(--weight-bold);
  }

  .card__status {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--text-xs);
  }
  .card__status--active {
    color: var(--status-available);
  }
  .card__status--stable {
    color: var(--muted);
  }

  .card__desc {
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .card__tags {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: auto; /* push tags + footer to the bottom for even card rows */
  }
  /* Amber-bordered tech chips. */
  .chip {
    font-size: var(--text-xs);
    color: var(--accent);
    border: 1px solid var(--accent-ring);
    border-radius: var(--radius-full);
    padding: 0 var(--space-2);
  }

  .card__foot {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-xs);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border);
  }
  .card__link {
    color: var(--green);
    text-decoration: none;
  }
  .card__link:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
  .card__stars {
    margin-left: auto;
    color: var(--dim);
  }
</style>
