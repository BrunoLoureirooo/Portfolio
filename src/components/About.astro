---
// About — the bio, sourced from the CV's Summary at build time (getCvContent,
// locale-aware). Falls back to a static line if the CV can't be parsed.
// NOTE: a CV Summary is third-person; that voice carries through to here. To
// read first-person on the site, write the CV summary in first person — it's
// the single source.
import Section from './Section.astro';
import { getCvContent } from '../lib/cvContent';

const { summary } = await getCvContent(Astro.currentLocale);
const bio =
  summary ||
  'Software engineer focused on backend systems — secure, production-ready services built to stay correct under load.';
---

<Section id="about" title="About" cmd="cat about.md">
  <div class="about">
    <p>{bio}</p>
  </div>
</Section>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .about p {
    max-width: var(--measure);
    color: var(--text);
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
  }
</style>
