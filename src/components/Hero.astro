---
// Hero — the 10-second hook. Terminal-framed identity: prompt line, big
// glowing green name, an amber typewriter tagline, a neofetch panel, and
// quick links. See docs/features/hero.md for the full spec.
//
// Motion (per /design-motion-principles, Jakub-weighted): a subtle
// materialize entrance, a typed-on tagline, and one blinking caret. All
// reduced-motion paths live in this component's <style>/<script>.
//
// PHASE 2 TODO: the neofetch "Langs" line + activity could hydrate from the
// GitHub API. This static markup stays the fallback — keep it stable.

import { cvPath } from '../lib/cv';
import { getCvContent } from '../lib/cvContent';
import { useTranslations } from '../i18n/utils';

// Picks /CV.pdf or /CV_PT.pdf based on the current route's locale.
const cvHref = cvPath(Astro.currentLocale);

// Translation accessor for the current locale.
const t = useTranslations(Astro.currentLocale);

// Contact links come from the CV header — single source, no duplication.
const { contact } = await getCvContent(Astro.currentLocale);

// Neofetch rows: each is a (label key, value key) pair into the dictionary.
const info = [
  { k: 'hero.nf.os', v: 'hero.nf.os.value' },
  { k: 'hero.nf.role', v: 'hero.nf.role.value' },
  { k: 'hero.nf.uptime', v: 'hero.nf.uptime.value' },
  { k: 'hero.nf.shell', v: 'hero.nf.shell.value' },
  { k: 'hero.nf.location', v: 'hero.nf.location.value' },
  { k: 'hero.nf.langs', v: 'hero.nf.langs.value' },
] as const;
---

<section class="hero" id="hero" aria-label="Introduction">
  <div class="hero__inner">
    <p class="hero__lastlogin">{t('hero.lastlogin')}</p>

    <p class="hero__cmd">
      <span class="hero__user">bruno@portfolio</span><span class="hero__mark"
        >:~$</span
      > {t('hero.cmd')}
    </p>

    <h1 class="hero__name">Bruno Loureiro</h1>

    <p class="hero__tagline" data-typewriter>
      <span class="hero__tagline-text">{t('hero.tagline')}</span><span
        class="caret"
        aria-hidden="true"></span>
    </p>

    <div class="neofetch">
      <div class="neofetch__logo" aria-hidden="true">BL</div>
      <div class="neofetch__body">
        {/* neofetch's title line: user@host + a separator rule, like the real tool */}
        <p class="neofetch__host">bruno@portfolio</p>
        <dl class="neofetch__info">
          {
            info.map((row) => (
              <div class="neofetch__row">
                <dt>{t(row.k)}</dt>
                <dd>{t(row.v)}</dd>
              </div>
            ))
          }
          <div class="neofetch__row neofetch__row--status">
            <dt>{t('hero.nf.status')}</dt>
            <dd>
              <span class="neofetch__dot" aria-hidden="true"></span>{t('hero.nf.status.value')}
            </dd>
          </div>
        </dl>
      </div>
    </div>

    <ul class="hero__links">
      <li>
        <a class="pill" href={contact.github} rel="me">
          {t('hero.link.github')}
        </a>
      </li>
      <li>
        <a class="pill" href={`mailto:${contact.email}`}>{t('hero.link.email')}</a>
      </li>
      <li>
        <a class="pill pill--amber" href={cvHref} download>{t('hero.link.resume')}</a>
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    min-height: 78vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-16) var(--space-12);
  }

  .hero__inner {
    width: 100%;
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  /* Entrance: subtle materialize, lightly staggered. `backwards` fill holds
     the from-state during the delay so nothing flashes in at full opacity. */
  .hero__inner > * {
    animation: hero-enter 450ms var(--ease-out-quart) backwards;
    animation-delay: calc(var(--i, 0) * 70ms);
  }
  .hero__inner > *:nth-child(1) {
    --i: 0;
  }
  .hero__inner > *:nth-child(2) {
    --i: 1;
  }
  .hero__inner > *:nth-child(3) {
    --i: 2;
  }
  .hero__inner > *:nth-child(4) {
    --i: 3;
  }
  .hero__inner > *:nth-child(5) {
    --i: 4;
  }
  .hero__inner > *:nth-child(6) {
    --i: 5;
  }

  @keyframes hero-enter {
    from {
      opacity: 0;
      transform: translateY(8px);
      filter: blur(4px);
    }
    to {
      opacity: 1;
      transform: none;
      filter: blur(0);
    }
  }

  .hero__lastlogin {
    font-size: var(--text-sm);
    color: var(--dim);
    margin-bottom: var(--space-3);
  }

  .hero__cmd {
    font-size: var(--text-sm);
    color: var(--fg);
    margin-bottom: var(--space-5);
  }
  .hero__user {
    color: var(--green);
  }
  .hero__mark {
    color: var(--accent);
  }

  /* Green is the hero: the name is the one bright-green glowing display line. */
  .hero__name {
    font-size: var(--text-hero);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--green);
    text-shadow: var(--glow-green);
    margin-bottom: var(--space-4);
  }

  .hero__tagline {
    font-size: var(--text-xl);
    color: var(--accent);
    margin-bottom: var(--space-10);
    /* Reserve line height so the typed text doesn't reflow the layout. */
    min-height: 1.4em;
  }

  /* Block caret — terminal idiom. step-end gives a hard on/off blink. */
  .caret {
    display: inline-block;
    width: 0.6em;
    height: 1.05em;
    margin-left: 0.08em;
    background-color: currentColor;
    vertical-align: text-bottom;
    animation: caret-blink 1.06s step-end infinite;
  }

  @keyframes caret-blink {
    0%,
    50% {
      opacity: 1;
    }
    50.01%,
    100% {
      opacity: 0;
    }
  }

  /* ---- Neofetch panel ---- */
  .neofetch {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-10);
    margin-bottom: var(--space-8);
    padding: var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background-color: var(--panel);
    box-shadow: var(--glow-window);
  }

  .neofetch__logo {
    flex: none;
    display: grid;
    place-items: center;
    width: 116px;
    height: 116px;
    border: 1px solid var(--green-line);
    border-radius: var(--radius-sm);
    /* One-off display glyph: larger than the 2xl scale so the initials fill
       the box the way neofetch's ASCII logo does. */
    font-size: 2.25rem;
    font-weight: var(--weight-bold);
    letter-spacing: 0.05em;
    color: var(--green);
    text-shadow: var(--glow-green);
  }

  .neofetch__body {
    flex: 1 1 240px;
    display: flex;
    flex-direction: column;
  }

  /* neofetch title line: dim user@host with a green hairline beneath it. */
  .neofetch__host {
    width: fit-content;
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    font-size: var(--text-sm);
    color: var(--muted);
    border-bottom: 1px solid var(--green-line);
  }

  .neofetch__info {
    display: grid;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }
  .neofetch__row {
    display: grid;
    grid-template-columns: 5.5em 1fr;
    gap: var(--space-3);
  }
  .neofetch__row dt {
    color: var(--green);
  }
  .neofetch__row dd {
    color: var(--fg);
  }
  /* Colon separator pinned to the value-column start, so colons align down
     the list regardless of label width — the neofetch `label : value` look. */
  .neofetch__row dd::before {
    content: ':';
    margin-right: 0.6em;
    color: var(--dim);
  }
  /* Blank line before Status — neofetch sets the status/uptime block apart. */
  .neofetch__row--status {
    margin-top: var(--space-3);
  }
  .neofetch__row--status dd {
    color: var(--status-available);
  }
  .neofetch__dot {
    display: inline-block;
    width: 0.55em;
    height: 0.55em;
    margin-right: 0.5em;
    border-radius: var(--radius-full);
    background-color: var(--status-available);
    vertical-align: middle;
  }

  /* ---- Quick links ---- */
  .hero__links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .pill {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--fg);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    padding: var(--space-2) var(--space-4);
    transition:
      color var(--duration-base) var(--ease-out-quart),
      border-color var(--duration-base) var(--ease-out-quart),
      box-shadow var(--duration-base) var(--ease-out-quart);
  }
  .pill:hover,
  .pill:focus-visible {
    color: var(--green);
    border-color: var(--green);
    box-shadow: var(--glow-green);
    text-decoration: none;
  }
  /* Amber resume pill: the one amber CTA among the links. */
  .pill--amber {
    color: var(--accent);
    border-color: var(--accent);
  }
  .pill--amber:hover,
  .pill--amber:focus-visible {
    color: var(--bg);
    background-color: var(--accent);
    border-color: var(--accent);
    box-shadow: none;
  }

  /* ---- Reduced motion: no materialize, no blink, caret pinned solid ---- */
  @media (prefers-reduced-motion: reduce) {
    .caret {
      animation: none;
      opacity: 1;
    }
  }
</style>

<script>
  // Typewriter for the amber tagline. Progressive enhancement: the full text
  // is already in the DOM (screen readers + no-JS see it). When motion is
  // allowed, we clear it and type it back ~42ms/char. Reduced-motion users
  // keep the instant full text.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const el = document.querySelector<HTMLElement>(
    '[data-typewriter] .hero__tagline-text',
  );

  if (el && !reduce) {
    const full = el.textContent ?? '';
    const speed = 42; // matches --type-speed
    let timer: number | undefined;
    const run = () => {
      window.clearTimeout(timer);
      el.textContent = '';
      let i = 0;
      const type = () => {
        i += 1;
        el.textContent = full.slice(0, i);
        if (i < full.length) timer = window.setTimeout(type, speed);
      };
      type();
    };
    run();
    // Re-type when the recruiter program is (re)shown via a view swap (DESIGN §8).
    document.addEventListener('view:changed', (e) => {
      if ((e as CustomEvent).detail === 'recruiter') run();
    });
  }
</script>
