---
// Section — shared wrapper for every content section below the hero.
// Standardizes: consistent vertical rhythm, max-width, and the prompt-style
// marker that gives the site its terminal wayfinding (e.g. "~/about").
//
// Props:
//   marker — the path label shown in mono accent (the brand's section cue)
//   id     — anchor target for in-page nav links
//   title  — visible section heading (sans); also labels the section for a11y
interface Props {
  marker: string;
  id: string;
  title: string;
}

const { marker, id, title } = Astro.props;
const headingId = `${id}-heading`;
---

<section class="section" id={id} aria-labelledby={headingId}>
  <div class="section__inner">
    <p class="section__marker" aria-hidden="true">{marker}</p>
    <h2 class="section__title" id={headingId}>{title}</h2>
    <div class="section__body">
      <slot />
    </div>
  </div>
</section>

<style>
  .section {
    padding-block: var(--space-16);
    border-top: 1px solid var(--border);
  }

  .section__inner {
    max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--space-6);
  }

  /* Prompt-style marker: mono, accent — terminal wayfinding, not an eyebrow */
  .section__marker {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    margin-bottom: var(--space-2);
  }

  .section__title {
    font-size: var(--text-2xl);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-8);
  }
</style>
