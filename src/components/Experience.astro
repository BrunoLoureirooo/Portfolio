---
// Experience — `git log` as a vertical timeline, newest-first. PRIMARY source
// is the CV (getCvContent, locale-aware); if parsing yields nothing it falls
// back to the `experience` content collection. The newest node glows.
import Section from './Section.astro';
import { getCollection } from 'astro:content';
import { getCvContent } from '../lib/cvContent';
import { useTranslations } from '../i18n/utils';

const t = useTranslations(Astro.currentLocale);

// Common shape both sources normalize into for rendering.
type Entry = {
  period: string; // "[ 2025 — present ]"
  title: string;
  company: string;
  bullets: string[];
  stack: string[];
};

const yearOf = (mmYYYY: string) => mmYYYY.split('/')[1] ?? mmYYYY;

const cv = await getCvContent(Astro.currentLocale);

let entries: Entry[];
if (cv.experience.length) {
  entries = cv.experience.map((r) => ({
    period: `[ ${yearOf(r.start)} — ${r.end ? yearOf(r.end) : 'present'} ]`,
    title: r.title,
    company: r.company,
    bullets: r.bullets,
    stack: r.stack,
  }));
} else {
  const coll = (await getCollection('experience')).sort(
    (a, b) => b.data.start.getTime() - a.data.start.getTime(),
  );
  entries = coll.map((e) => ({
    period: `[ ${e.data.start.getUTCFullYear()} — ${e.data.end ? e.data.end.getUTCFullYear() : 'present'} ]`,
    title: e.data.title,
    company: e.data.company,
    bullets: [e.data.description],
    stack: e.data.stack,
  }));
}
---

<Section id="experience" title={t('section.experience.title')} cmd={t('section.experience.cmd')}>
  <ol class="timeline">
    {
      entries.map((entry, idx) => (
        <li class="entry">
          <span
            class:list={['entry__node', { 'entry__node--head': idx === 0 }]}
            aria-hidden="true"
          />
          <p class="entry__period">{entry.period}</p>
          <h3 class="entry__role">
            {entry.title} @ {entry.company}
          </h3>
          <ul class="entry__bullets">
            {entry.bullets.map((b) => (
              <li>{b}</li>
            ))}
          </ul>
          {entry.stack.length > 0 && (
            <p class="entry__stack">{entry.stack.join(' · ')}</p>
          )}
        </li>
      ))
    }
  </ol>
</Section>

<style>
  .timeline {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Each entry carries the connecting line as its own left border, so the
     line is continuous down the list without a separate element. */
  .entry {
    position: relative;
    margin-left: 4px;
    padding-left: var(--space-6);
    padding-bottom: var(--space-8);
    border-left: 1px solid var(--border);
  }
  .entry:last-child {
    padding-bottom: 0;
  }

  .entry__node {
    position: absolute;
    left: -5px;
    top: 0.3em;
    width: 9px;
    height: 9px;
    border-radius: var(--radius-full);
    background-color: var(--dim);
    /* Punch the node out of the background so the line doesn't show through. */
    box-shadow: 0 0 0 3px var(--bg);
  }
  .entry__node--head {
    background-color: var(--green);
    box-shadow:
      0 0 0 3px var(--bg),
      var(--glow-green);
  }

  .entry__period {
    color: var(--accent);
    font-size: var(--text-xs);
    margin-bottom: var(--space-1);
  }
  .entry__role {
    color: var(--green);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    margin-bottom: var(--space-2);
  }
  .entry__bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3);
    max-width: var(--measure);
    display: grid;
    gap: var(--space-2);
  }
  .entry__bullets li {
    position: relative;
    padding-left: var(--space-4);
    color: var(--fg);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }
  /* Terminal-style bullet marker in amber. */
  .entry__bullets li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .entry__stack {
    color: var(--dim);
    font-size: var(--text-xs);
  }
</style>
