---
// BaseLayout — the single shell every page renders inside.
// The code between the --- fences runs at build time only (never ships to
// the browser). Styles imported here apply site-wide.
//
// The whole page is ONE terminal window: a centered frame with a sticky
// title bar (traffic-light dots + live ticking clock). Sections render
// inside the <slot />. Nav bar + CRT layer land in later steps.
import '../styles/tokens.css';
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import EntryMoment from '../components/EntryMoment.astro';
import SEO from '../components/SEO.astro';
import Analytics from '../components/Analytics.astro';
import { useTranslations } from '../i18n/utils';
import { startView } from '../config';

interface Props {
  title?: string;
  description?: string;
}

// Astro.currentLocale is set by the i18n router based on the URL
// (/ → "en", /pt/ → "pt"). Falls back to "en" for safety.
const lang = Astro.currentLocale ?? 'en';
const t = useTranslations(lang);

// title/description default to the locale's dictionary values; a page can still
// override per-page by passing the prop.
const { title = t('meta.title'), description = t('meta.description') } = Astro.props;

// Split the window title around its path token so the controller can swap just
// that segment per program (~ / ~/dev / ~/studio). Default ~/dev = recruiter,
// which is also what no-JS/crawlers see.
const [titlePre, titlePost = ''] = t('chrome.title').split('~/dev');
---

<!doctype html>
<html lang={lang} data-start-view={startView}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- No-flash view selector. Runs BEFORE first paint so returning
         visitors never see the audience-selector blink. Sets data-view on
         <html>; CSS keys off it to show exactly one program. With JS off the
         attribute stays unset → CSS default reveals the recruiter view (real
         content for crawlers/no-JS), not a dead selector. -->
    <script is:inline>
      (function () {
        var html = document.documentElement;
        var start = html.dataset.startView; // 'ask' | 'recruiter' | 'client'
        var view;
        if (start === 'recruiter' || start === 'client') {
          view = start; // pinned override always wins (for previewing)
        } else {
          try {
            view = localStorage.getItem('tp_view');
          } catch (e) {
            /* storage blocked (private mode) — fall through to the selector */
          }
          if (view !== 'recruiter' && view !== 'client') view = 'ask';
        }
        html.dataset.view = view;
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO title={title} description={description} lang={lang} />
    <Analytics />

    <!-- JetBrains Mono — the single font. Preconnect first so the CSS
         request isn't blocked on DNS/TLS to the font host. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap"
    />
  </head>
  <body>
    <div class="window">
      <!-- Sticky chrome: title bar + nav pin to the viewport as one block. -->
      <div class="chrome">
        <header class="titlebar">
          <div class="titlebar__dots">
            <button
              type="button"
              class="dot dot--red"
              data-set-view="ask"
              aria-label={t('chrome.close')}
              title={t('chrome.close')}></button>
            <span class="dot dot--yellow" aria-hidden="true"></span>
            <span class="dot dot--green" aria-hidden="true"></span>
          </div>
          <p class="titlebar__title">{titlePre}<span id="tb-path">~/dev</span>{titlePost}</p>
          <div class="titlebar__meta">
            <span class="titlebar__enc">UTF-8</span>
            <time class="titlebar__clock" id="clock" aria-label={t('chrome.clock')}
              >--:--:--</time
            >
          </div>
        </header>

        <Nav />
      </div>

      <!-- Audience selector: visible only when data-view='ask'. Sits beside
           the program content (the <slot/>); CSS shows exactly one. -->
      <EntryMoment />

      <slot />
    </div>

    <!-- CRT atmosphere — purely decorative overlay sitting above everything
         (pointer-events: none, so it never intercepts clicks). Scanlines +
         vignette are static; the scan band and flicker animate. All motion
         is frozen under prefers-reduced-motion. -->
    <div class="crt" aria-hidden="true">
      <div class="crt__band"></div>
    </div>

    <script>
      // Live clock in the title bar: HH:MM:SS, updated every second.
      // Vanilla + tiny — no island needed for a single text node.
      const el = document.getElementById('clock');
      if (el) {
        const pad = (n: number) => String(n).padStart(2, '0');
        const tick = () => {
          const d = new Date();
          el.textContent = `${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}`;
        };
        tick();
        setInterval(tick, 1000);
      }
    </script>

    <script>
      // View controller — the one "island" for v2 audience-gated views.
      // Both programs' markup ships in the static HTML; this only flips an
      // attribute, so swaps are instant (no fetch, no re-render).
      //
      // Delegated so it works for any current/future trigger: the entry-moment
      // selector cards and the nav switch pill all carry `data-set-view`.
      // Title-bar path segment, program-aware (DESIGN §3).
      function viewPath(view: string | undefined) {
        return view === 'client' ? '~/studio' : view === 'recruiter' ? '~/dev' : '~';
      }
      function syncPath(view: string | undefined) {
        const el = document.getElementById('tb-path');
        if (el) el.textContent = viewPath(view);
      }
      syncPath(document.documentElement.dataset.view); // sync to the booted view

      function setView(view: string) {
        // Red traffic-light dot → back to the audience selector ("close" the
        // program). Forget the saved choice so a later reload also lands here.
        if (view === 'ask') {
          document.documentElement.dataset.view = 'ask';
          syncPath('ask');
          try {
            localStorage.removeItem('tp_view');
          } catch (e) {
            /* storage blocked — nothing to clear */
          }
          window.scrollTo(0, 0);
          return;
        }
        if (view !== 'recruiter' && view !== 'client') return;
        document.documentElement.dataset.view = view;
        syncPath(view);
        try {
          localStorage.setItem('tp_view', view);
        } catch (e) {
          /* storage blocked — selection just won't persist across visits */
        }
        window.scrollTo(0, 0); // each program reads top-down from its hero
        // a11y: the clicked control just became display:none — move focus into
        // the newly shown program so keyboard users aren't dropped to <body>.
        const shown = document.querySelector(`[data-view-content="${view}"]`);
        const heading = shown?.querySelector<HTMLElement>('h1, h2');
        if (heading) {
          heading.setAttribute('tabindex', '-1');
          heading.focus({ preventScroll: true });
        }
        // Tell the active hero to retype its tagline for the new program.
        document.dispatchEvent(new CustomEvent('view:changed', { detail: view }));
      }

      document.addEventListener('click', (e) => {
        const trigger = (e.target as HTMLElement).closest('[data-set-view]');
        if (!trigger) return;
        e.preventDefault();
        setView((trigger as HTMLElement).dataset.setView ?? '');
      });
    </script>
  </body>
</html>

<style>
  /* Page background sits behind the window: near-black with a faint green
     radial glow bleeding down from the top edge (phosphor ambience). */
  body {
    background-color: var(--page-bg);
    background-image: radial-gradient(
      120% 60% at 50% 0%,
      var(--green-dim),
      transparent 60%
    );
    background-attachment: fixed;
  }

  /* The terminal window — centered frame holding the whole site.
     No overflow clip here: that would trap the sticky title bar inside
     the window instead of pinning it to the viewport. The title bar
     carries its own rounded top corners to match the frame. */
  .window {
    position: relative;
    max-width: var(--container);
    margin: var(--space-8) auto var(--space-16);
    background-color: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-window);
    box-shadow: var(--glow-window);
  }

  /* Sticky chrome block — title bar + nav pin to the viewport together. */
  .chrome {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
  }

  .titlebar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    background-color: var(--panel);
    border-bottom: 1px solid var(--border);
    border-top-left-radius: var(--radius-window);
    border-top-right-radius: var(--radius-window);
  }

  /* macOS-style traffic-light dots (decorative, not interactive) */
  .titlebar__dots {
    display: flex;
    gap: var(--space-2);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: var(--radius-full);
  }

  .dot--red {
    background-color: var(--dot-red);
  }
  .dot--yellow {
    background-color: var(--dot-yellow);
  }
  .dot--green {
    background-color: var(--dot-green);
  }

  /* The red dot is interactive: it closes the active program and returns to the
     audience selector. Reset the native button chrome; keep the 12px circle. */
  button.dot {
    padding: 0;
    border: none;
    font: inherit;
    cursor: pointer;
    position: relative;
    transition: filter var(--duration-base) var(--ease-out-quart);
  }
  /* Enlarge the tap/click area without changing the dot's visual size. */
  button.dot::after {
    content: '';
    position: absolute;
    inset: -7px;
  }
  /* macOS idiom: an ✕ glyph fades in over the red dot on hover/focus,
     hinting the "close → back to selector" action. Dark mark on red. */
  button.dot::before {
    content: '×';
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-size: 11px;
    line-height: 1;
    color: rgba(0, 0, 0, 0.7);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out-quart);
  }
  button.dot:hover::before,
  button.dot:focus-visible::before {
    opacity: 1;
  }
  button.dot:hover {
    filter: brightness(1.3);
  }
  button.dot:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 3px;
  }

  .titlebar__title {
    grid-column: 2;
    text-align: center;
    font-size: var(--text-xs);
    color: var(--muted);
    white-space: nowrap;
  }

  .titlebar__meta {
    justify-self: end;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  /* Tabular numbers so the ticking seconds don't shift width. */
  .titlebar__clock {
    color: var(--green);
    font-variant-numeric: tabular-nums;
  }

  /* The centered title is the first thing to drop on narrow screens —
     dots and clock are the load-bearing chrome. */
  @media (max-width: 640px) {
    .titlebar__title {
      display: none;
    }
  }

  /* ---- CRT atmosphere ---------------------------------------------------
     Full-viewport overlay above all content. The subtle flicker rides on
     the container's opacity; scanlines + vignette live in pseudo-elements. */
  .crt {
    position: fixed;
    inset: 0;
    z-index: var(--z-crt);
    pointer-events: none;
    animation: crt-flicker 4s steps(1) infinite;
  }

  /* Scanlines — faint dark horizontal rule every ~3px. */
  .crt::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.16) 3px
    );
  }

  /* Vignette — darkens the corners so the screen reads as curved glass. */
  .crt::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      120% 120% at 50% 50%,
      transparent 55%,
      rgba(0, 0, 0, 0.55) 100%
    );
  }

  /* Drifting scan band — a soft green sweep travelling slowly down-screen. */
  .crt__band {
    position: absolute;
    left: 0;
    right: 0;
    height: 28%;
    background: linear-gradient(
      to bottom,
      transparent,
      rgba(0, 255, 0, 0.035),
      transparent
    );
    animation: crt-scan 7s linear infinite;
  }

  @keyframes crt-scan {
    from {
      transform: translateY(-110%);
    }
    to {
      transform: translateY(460%);
    }
  }

  /* Flicker — barely-there brightness wobble. Kept tiny on purpose. */
  @keyframes crt-flicker {
    0%,
    97%,
    100% {
      opacity: 1;
    }
    98% {
      opacity: 0.92;
    }
    99% {
      opacity: 0.97;
    }
  }

  /* Reduced motion: keep the static scanlines + vignette, kill all movement. */
  @media (prefers-reduced-motion: reduce) {
    .crt {
      animation: none;
    }
    .crt__band {
      display: none;
    }
  }
</style>
